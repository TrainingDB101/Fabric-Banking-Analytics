expression 'DirectQuery to AS - sm_gold_analytics' =
		let
		    Source = AnalysisServices.Database("powerbi://api.powerbi.com/v1.0/myorg/fabric_banking_analytics_ws", "sm_gold_analytics"),
		    Cubes = Table.Combine(Source[Data]),
		    Cube = Cubes{[Id="Model", Kind="Cube"]}[Data]
		in
		    Cube
	lineageTag: d55153a7-1ec5-41c6-b4a6-f8e6a9e28b75

	annotation PBI_IncludeFutureArtifacts = True

